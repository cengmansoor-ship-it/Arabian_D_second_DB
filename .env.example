# Copy to .env and fill in real values for local/production use.
# NEVER commit a real .env file. On Replit, set these as Secrets instead
# (see docs/operations/LOCAL_AND_REPLIT_RUNBOOK.md).

# --- Required ---
# Signs authentication JWTs and CSRF-related tokens. Use a long random string.
SESSION_SECRET=

# --- Server ---
# Port the API server listens on (the "Web App" workflow sets this for you).
PORT=8080

# development | production | test
NODE_ENV=development

# --- Database ---
# Defaults to local SQLite; set DB_DIALECT=mysql to switch to hosted MySQL.
DB_DIALECT=sqlite
# Path to the SQLite file (only used when DB_DIALECT=sqlite). Defaults to
# ./data/arabian-d.sqlite relative to artifacts/api-server.
SQLITE_STORAGE=

# MySQL connection (only used when DB_DIALECT=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=arabian_d
DB_USER=root
DB_PASSWORD=

# --- First-run admin account ---
# If unset, the seed script creates admin/admin123 for local development only.
# Always set both before deploying to production.
ADMIN_USERNAME=
ADMIN_PASSWORD=
