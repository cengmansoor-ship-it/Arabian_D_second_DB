modules = ["nodejs-24", "python-base-3.13"]

[deployment]
deploymentTarget = "autoscale"

[workflows]
runButton = "Web App"

[[workflows.workflow]]
name = "Web App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "(PORT=8080 pnpm --filter @workspace/api-server run dev &) && PORT=5000 API_URL=http://localhost:8080 pnpm --filter @workspace/web run dev"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080
